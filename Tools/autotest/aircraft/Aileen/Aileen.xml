        </engine>
        
        
    </propulsion>
	
	<flight_control>
        <channel name="All">
            <summer name="Pitch Trim Sum">
                <!-- Credo sia collegato direttamente all'Equlibratore, no changes.-->
                <input>fcs/elevator-cmd-norm</input>
                <input>fcs/pitch-trim-cmd-norm</input>
                <clipto>
                    <min>-1</min>
                    <max>1</max>
                </clipto>
            </summer>
            <aerosurface_scale name="Elevator Control">
                <!-- EQUILIBRATORE DELTA_MAX-->
                <input>fcs/pitch-trim-sum</input>
                <range>
                    <min>-0.4535555556</min>
                    <max>0.4535555556</max>
                </range>
                <output>fcs/elevator-pos-rad</output>
            </aerosurface_scale>
            <aerosurface_scale name="Elevator Normalized">
                <!-- EQUILIBRATORE DELTA_MAX-->
                <input>fcs/elevator-pos-rad</input>
                <domain>
                    <min>-0.4535555556</min>
                    <max> 0.4535555556</max>
                </domain>
                <range>
                    <min>-1</min>
                    <max> 1</max>
                </range>
                <output>fcs/elevator-pos-norm</output>
            </aerosurface_scale>
            <summer name="Roll Trim Sum">
                <!-- Credo sia collegato all'Alettone, no changes.-->
                <input>fcs/aileron-cmd-norm</input>
                <input>fcs/roll-trim-cmd-norm</input>
                <clipto>
                    <min>-1</min>
                    <max>1</max>
                </clipto>
            </summer>
            <aerosurface_scale name="Left Aileron Control">
                <!-- ALETTONE DELTA_MAX-->
                <input>fcs/roll-trim-sum</input>
                <range>
                    <min>-0.175</min>
                    <max>0.175</max>
                </range>
                <output>fcs/left-aileron-pos-rad</output>
            </aerosurface_scale>
            <aerosurface_scale name="Right Aileron Control">
                <!-- ALETTONE DELTA_MAX-->
                <input>-fcs/roll-trim-sum</input>
                <range>
                    <min>-0.175</min>
                    <max>0.175</max>
                </range>
                <output>fcs/right-aileron-pos-rad</output>
            </aerosurface_scale>
            <aerosurface_scale name="Left aileron Normalized">
                <!-- ALETTONE DELTA_MAX-->
                <input>fcs/left-aileron-pos-rad</input>
                <domain>
                    <min>-0.175</min>
                    <max> 0.175</max>
                </domain>
                <range>
                    <min>-1</min>
                    <max> 1</max>
                </range>
                <output>fcs/left-aileron-pos-norm</output>
            </aerosurface_scale>
            <aerosurface_scale name="Right aileron Normalized">
                <!-- ALETTONE DELTA_MAX-->
                <input>fcs/right-aileron-pos-rad</input>
                <domain>
                    <min>-0.175</min>
                    <max> 0.175</max>
                </domain>
                <range>
                    <min>-1</min>
                    <max> 1</max>
                </range>
                <output>fcs/right-aileron-pos-norm</output>
            </aerosurface_scale>
            <summer name="Rudder Command Sum">
                <!-- Forse collegato al Timone. no changes.-->
                <input>fcs/rudder-cmd-norm</input>
                <input>fcs/yaw-trim-cmd-norm</input>
                <clipto>
                    <min>-1</min>
                    <max>1</max>
                </clipto>
            </summer>
            <aerosurface_scale name="Rudder Control">
                <!-- TIMONE DELTA_MAX ( NIENTE SUL FILE). Ho messo io 0.00-->
                <input>fcs/rudder-command-sum</input>
                <range>
                    <min>-0.00</min>
                    <max>0.00</max>
                </range>
                <output>fcs/rudder-pos-rad</output>
            </aerosurface_scale>
            <aerosurface_scale name="Rudder Normalized">
                <!-- TIMONE DELTA_MAX ( NIENTE SUL FILE). Ho messo io 0.00-->
                <input>fcs/rudder-pos-rad</input>
                <domain>
                    <min>-0.00</min>
                    <max> 0.00</max>
                </domain>
                <range>
                    <min>-1</min>
                    <max> 1</max>
                </range>
                <output>fcs/rudder-pos-norm</output>
            </aerosurface_scale>
        </channel>
        <!-- Elevator, Aileron e Rudder trovati! Per Rudder non ci sono i dati della Delta_max sul file di RA... -->
	</flight_control>
	
