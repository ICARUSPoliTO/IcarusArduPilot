	<flight_control>
		
		<channel name="Roll">
			<!-- Somma comando e trim -->
			<summer name="fcs/roll-trim-sum">
				<input>fcs/aileron-cmd-norm</input>
				<input>fcs/roll-trim-cmd-norm</input>
				<clipto>
				    <min>-1</min>
				    <max>1</max>
				</clipto>
			</summer>

			<!-- Alettone Sinistro -->
			<actuator name="fcs/left-aileron-control">
				<input>fcs/roll-trim-sum</input>
				<range>
				    <min>-0.175</min> <!-- ~10 gradi -->
				    <max> 0.175</max>
				</range>
				<!--  Ritardo e velocità massima di deflessione del servo (vedi doc)
				<lag> 20 </lag>
				<rate_limit> 1.0 </rate_limit> 
				-->
				<output>fcs/left-aileron-pos-rad</output> <!-- Letto dal bridge ArduPilot -->
			</actuator>

			<!-- Alettone Destro -->
			<actuator name="fcs/right-aileron-control">
				<input>-fcs/roll-trim-sum</input> <!-- Segno meno per movimento differenziale -->
				<range>
				    <min>-0.175</min>
				    <max> 0.175</max>
				</range>
				<!--  Ritardo e velocità massima di deflessione del servo (vedi doc)
				<lag> 20 </lag>
				<rate_limit> 1.0 </rate_limit> 
				-->
				<output>fcs/right-aileron-pos-rad</output>
			</actuator>

			<!-- Riporta la deflessione al comando (-1,1) corrispondente, comodo per comparare comando e risposta -->
			<aerosurface_scale name="fcs/left-aileron-normalized">
				<input>fcs/left-aileron-pos-rad</input>
				<domain>
				    <min>-0.175</min>
				    <max> 0.175</max>
				</domain>
				<range>
				    <min>-1</min>
				    <max> 1</max>
				</range>
				<output>fcs/left-aileron-pos-norm</output>
			</aerosurface_scale>

			<!-- Riporta la deflessione al comando (-1,1) corrispondente, comodo per comparare comando e risposta -->
			<aerosurface_scale name="fcs/right-aileron-normalized">
				<input>fcs/right-aileron-pos-rad</input>
				<domain>
				    <min>-0.175</min>
				    <max> 0.175</max>
				</domain>
				<range>
				    <min>-1</min>
				    <max> 1</max>
				</range>
				<output>fcs/right-aileron-pos-norm</output>
			</aerosurface_scale>
		</channel>
		
		<channel name="Pitch">
			<!-- Somma comando e trim -->
			<summer name="fcs/pitch-trim-sum">
				<input>fcs/elevator-cmd-norm</input>
				<input>fcs/pitch-trim-cmd-norm</input>
				<clipto>
				    <min>-1</min>
				    <max>1</max>
				</clipto>
			</summer>

			<!-- Converte il comando (-1, 1) in radianti -->
			<actuator name="fcs/elevator-control">
				<input>fcs/pitch-trim-sum</input>
				<range>
				    <min>-0.4536</min> <!-- ~26 gradi in basso -->
				    <max> 0.4536</max> <!-- ~26 gradi in alto -->
				</range>
				<!--  Ritardo e velocità massima di deflessione del servo (vedi doc)
				<lag> 20 </lag>
				<rate_limit> 1.0 </rate_limit> 
				-->
				<output>fcs/elevator-pos-rad</output> <!-- Proprietà letta dal bridge ArduPilot [3] -->
			</actuator>

			<!-- Riporta la deflessione al comando (-1,1) corrispondente, comodo per comparare comando e risposta -->
			<aerosurface_scale name="fcs/elevator-normalized">
				<input>fcs/elevator-pos-rad</input>
				<domain>
				    <min>-0.4536</min>
				    <max> 0.4536</max>
				</domain>
				<range>
				    <min>-1</min>
				    <max> 1</max>
				</range>
				<output>fcs/elevator-pos-norm</output>
			</aerosurface_scale>
		</channel>
		
		<channel name="Yaw">
			<!-- Somma dei comandi: ArduPilot SITL invia il comando rudder su fcs/rudder-cmd-norm -->
			<summer name="fcs/rudder-command-sum">
				<input>fcs/rudder-cmd-norm</input>
				<input>fcs/yaw-trim-cmd-norm</input> <!-- Trim JSBSim -->
				<clipto>
				    <min>-1</min>
				    <max>1</max>
				</clipto>
			</summer>

			<!-- Conversione dal comando (-1, 1) a deflessione dell'attuatore -->
			<actuator name="fcs/rudder-control"> <!-- actuator meglio di aerosurface_scale perchè permette di definire lag e rate_limit -->
				<input>fcs/rudder-command-sum</input>
				<range>
				    <min>-0.175</min>	<!-- Deflessione inventata tra +-10° -->
				    <max> 0.175</max>
				</range>
				<!--  Ritardo e velocità massima di deflessione del servo (vedi doc)
				<lag> 20 </lag>
				<rate_limit> 1.0 </rate_limit> 
				-->
				<output>fcs/rudder-pos-rad</output> <!-- Proprietà letta da ArduPilot -->
			</actuator>

			<!-- Riporta la deflessione al comando (-1,1) corrispondente, comodo per comparare comando e risposta -->
			<aerosurface_scale name="fcs/rudder-normalized">
				<input>fcs/rudder-pos-rad</input>
				<domain>
				    <min>-0.175</min>
				    <max> 0.175</max>
				</domain>
				<range>
				    <min>-1</min>
				    <max> 1</max>
				</range>
				<output>fcs/rudder-pos-norm</output>
			</aerosurface_scale>
		</channel>
		
	</flight_control>
	
