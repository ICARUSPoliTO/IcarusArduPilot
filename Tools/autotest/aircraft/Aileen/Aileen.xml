                <y> 1 </y>
                <z> 0.03 </z>
            </location>
            <orient unit="DEG"> <!--Orientamento del motore -->
                <roll> 0.0 </roll>
                <pitch> 0 </pitch>
                <yaw> 0 </yaw>
            </orient>
            <feed>0</feed> <!--serbatoio da cui prende il carburante (0 se c'è solo un motore) -->
            <thruster file="thruster">
                <location unit="M"> <!--Posizione del thruster rispetto a CM, da modificare(?) -->
                    <x> 0.692 </x>
                    <y> 0 </y>
                    <z> 0.03 </z>
                </location>
                <orient unit="DEG">
                    <roll> 0.0 </roll>
                    <pitch> 0.0 </pitch>
                    <yaw> 0.0 </yaw>
                </orient>
                <p_factor>1.0</p_factor> <!-- effetto giroscopico dell'elica -->
            </thruster>
        </engine>
		<engine file="engine">
            <location unit="M"> <!--Posizione del motore rispetto a CM, da modificare(?) -->
                <x> 0.692 </x>
                <y> -1 </y>
                <z> 0.03 </z>
            </location>
            <orient unit="DEG"> <!--Orientamento del motore -->
                <roll> 0.0 </roll>
